  "url": "https://ir.aboutamazon.com/",
  "turns": [
    {
      "speaker_id": "andy-jassy",
      "speaker_name": "Andy Jassy",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "AWS finished 2025 with $127.4 billion in annual revenue, well ahead of the $120 billion target we set at the beginning of the year. Q4 AWS revenue was $31.8 billion, up 20% year-over-year. Our infrastructure investment in 2025 totaled $104.2 billion — the largest in our history — and we are committed to investing at least as much in 2026. AI workloads now represent approximately 30% of net new AWS workloads. We expect AWS to grow 20%+ in 2026."
    },
    {
      "speaker_id": "brian-olsavsky",
      "speaker_name": "Brian Olsavsky",
      "speaker_role": "CFO",
      "timestamp": "00:20:00",
      "text": "Q4 net sales were $187.8 billion, up 10% year-over-year. Full-year net sales were $678.8 billion. Operating income for Q4 was $21.2 billion. For Q1 2026, we are guiding net sales to $186–191 billion and operating income of $14–18 billion. AWS Q1 2026 revenue growth is expected to remain above 20%."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:38:00",
      "text": "Our next question comes from Mark Mahaney at Evercore ISI."
    },
    {
      "speaker_id": "analyst-mark-mahaney",
      "speaker_name": "Mark Mahaney",
      "speaker_role": "Analyst",
      "timestamp": "00:38:20",
      "text": "Andy, AI workloads at 30% of net new workloads is a significant figure. Can you speak to how that's influencing your infrastructure roadmap and pricing strategy for AI services?"
    }
  ],
