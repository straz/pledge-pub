{
  "company_id": "microsoft",
  "title": "Microsoft Q2 2025 Earnings Call",
  "datetime": "2025-07-30T21:00:00Z",
  "period": "CY2025_Q2",
  "location": "Redmond, WA",
  "url": "https://investor.microsoft.com/",
  "turns": [
    {
      "speaker_id": "satya-nadella",
      "speaker_name": "Satya Nadella",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Azure grew 35% in Q2 2025, with AI contributing 18 percentage points. We crossed $100 billion in annualized Azure revenue run rate this quarter. Microsoft 365 Copilot seat count doubled quarter-over-quarter to 30 million seats. Our capital expenditures were $21.4 billion, up 53% year-over-year, as we build capacity ahead of demand. We are on track for Microsoft Cloud to exceed $200 billion in annual revenue in fiscal year 2026."
    },
    {
      "speaker_id": "amy-hood",
      "speaker_name": "Amy Hood",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Total revenue was $73.4 billion, up 14%. Intelligent Cloud revenue was $28.5 billion, up 23%. Operating margin was 45.0%. For Q3, we expect Azure growth of 35–36% in constant currency and total revenue of $74.5–75.5 billion."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Amy, capex up 53% — can you help frame what your capacity utilization looks like and when you expect demand to catch up to the infrastructure you're building?"
    }
  ],
