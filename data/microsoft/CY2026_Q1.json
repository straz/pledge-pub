  "turns": [
    {
      "speaker_id": "satya-nadella",
      "speaker_name": "Satya Nadella",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Azure grew 40% in Q1 2026, the fastest in four years. AI contributed 22 percentage points. Copilot seat count has reached 90 million across Microsoft 365. We launched Copilot Wave 3 in March — bringing autonomous agent capabilities that can complete multi-step business processes without human intervention. Early enterprise pilots show productivity gains of 30–40% for targeted knowledge worker tasks. We expect Copilot to contribute meaningfully to revenue growth in the second half of 2026."
    },
    {
      "speaker_id": "amy-hood",
      "speaker_name": "Amy Hood",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Q1 2026 revenue was $82.6 billion, up 17%. Operating margin was 47.4%. Intelligent Cloud revenue was $33.9 billion, up 27%. For Q2 2026, we expect Azure growth of 40–41% and total revenue of $84–85 billion. Full-year 2026 capex is tracking to the $85–90 billion range."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:38:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:38:20",
      "text": "Satya, 30–40% productivity gains from Copilot Wave 3 — how are you measuring that, and does it create pricing power for the next Copilot tier?"
    }
  ],
