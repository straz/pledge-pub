{
  "company_id": "microsoft",
  "title": "Microsoft Q4 2025 Earnings Call",
  "datetime": "2026-01-29T21:00:00Z",
  "period": "CY2025_Q4",
  "location": "Redmond, WA",
  "url": "https://investor.microsoft.com/",
  "turns": [
    {
      "speaker_id": "satya-nadella",
      "speaker_name": "Satya Nadella",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Azure grew 38% in Q4 2025, our fastest growth in three years, ahead of guidance. Full calendar year 2025 Azure growth was 34% — well above 30% as we committed. Microsoft 365 Copilot has 70 million paid seats entering 2026. We expect Azure to approach 40% growth in Q1 2026 as wave 3 of our global data center expansion begins delivering capacity. We are raising our full-year 2026 capex guidance to $85–90 billion."
    },
    {
      "speaker_id": "amy-hood",
      "speaker_name": "Amy Hood",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Q4 revenue was $79.1 billion, up 15%. Full-year 2025 revenue was $299.4 billion, approaching $300 billion for the first time. Operating margin was 46.9%. For Q1 2026, we expect Azure growth of 39–40% and total revenue of $82–83 billion."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:38:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:38:20",
      "text": "Amy, approaching $300 billion in revenue with Azure accelerating — how do you think about the path to $400 billion and the capital intensity required to get there?"
    }
  ],
