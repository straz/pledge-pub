  "turns": [
    {
      "speaker_id": "satya-nadella",
      "speaker_name": "Satya Nadella",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Fiscal Q4 was strong across our commercial cloud business. Revenue was $64.7 billion, up 15% year-over-year. Azure and other cloud services grew 29% year-over-year. GitHub Copilot now has 1.8 million paid subscribers, and we expect to reach 3 million subscribers by the end of calendar year 2024. AI is the key driver of Microsoft 365 Copilot commercial deployments, which more than doubled quarter-over-quarter."
    },
    {
      "speaker_id": "amy-hood",
      "speaker_name": "Amy Hood",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Commercial cloud revenue was $36.8 billion, up 21% year-over-year. Operating income was $27.9 billion at a 43% operating margin. For fiscal Q1 2025, we expect Azure growth of 28 to 29% in constant currency. We expect to see Azure growth reaccelerate in the second half of fiscal 2025 as AI capacity constraints are relieved and new data centers come online. Capital expenditure was $19 billion this quarter."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Brent Thill at Jefferies."
    },
    {
      "speaker_id": "analyst-brent-thill",
      "speaker_name": "Brent Thill",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Satya, can you characterize the pipeline for Microsoft 365 Copilot enterprise deployments and what's the most common friction point in the sales process today?"
    }
  ],
