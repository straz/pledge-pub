  "title": "Microsoft Q1 2025 Earnings Call",
  "datetime": "2025-04-30T21:00:00Z",
  "period": "CY2025_Q1",
  "location": "Redmond, WA",
  "url": "https://investor.microsoft.com/",
  "turns": [
    {
      "speaker_id": "satya-nadella",
      "speaker_name": "Satya Nadella",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Microsoft Cloud revenue grew 21% to $42.4 billion in Q1 2025. Azure grew 33%, with AI services contributing 16 percentage points of that growth — up from 13 points last quarter. GitHub Copilot now has 15 million paid users across more than 100,000 organizations. We expect Azure to maintain greater than 30% growth through the rest of 2025 as AI workload adoption accelerates. Copilot is now embedded in every Microsoft product with more than 50 million users."
    },
    {
      "speaker_id": "amy-hood",
      "speaker_name": "Amy Hood",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Q1 revenue was $70.1 billion, up 13% year-over-year. Operating income was $32.0 billion with a 45.6% operating margin. Intelligent Cloud segment revenue was $26.8 billion, up 21%. We expect Q2 revenue of $72.1–73.1 billion and Azure growth of 34–35% in constant currency."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Satya, AI contributing 16 points to Azure growth is remarkable. Can you decompose that between training and inference workloads, and where you see the larger TAM?"
    }
  ],
