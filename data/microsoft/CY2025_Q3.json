{
  "company_id": "microsoft",
  "title": "Microsoft Q3 2025 Earnings Call",
  "datetime": "2025-10-29T21:00:00Z",
  "period": "CY2025_Q3",
  "location": "Redmond, WA",
  "url": "https://investor.microsoft.com/",
  "turns": [
    {
      "speaker_id": "satya-nadella",
      "speaker_name": "Satya Nadella",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Azure grew 36% in Q3, with AI contributing 20 percentage points. The inflection in AI revenue is now clear and self-reinforcing. Microsoft 365 Copilot exceeded 50 million paid seats, adding 20 million in a single quarter — the fastest enterprise software adoption curve we have ever seen. We expect Azure growth to reaccelerate toward 40% as our new data centers come online through 2026."
    },
    {
      "speaker_id": "amy-hood",
      "speaker_name": "Amy Hood",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Q3 revenue was $76.8 billion, up 16%. Operating income was $36.1 billion, margin of 47.0%. Intelligent Cloud was $30.2 billion, up 25%. For Q4, we expect Azure growth of 37–38% in constant currency and total revenue of $78.5–79.5 billion."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Satya, 50 million Copilot seats in a single quarter of net adds — can you break down commercial versus SMB, and what does churn look like at this scale?"
    }
  ],
