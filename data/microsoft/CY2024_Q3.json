  "location": "Redmond, WA",
  "url": "https://www.microsoft.com/en-us/investor/",
  "turns": [
    {
      "speaker_id": "satya-nadella",
      "speaker_name": "Satya Nadella",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Fiscal Q1 2025 was a strong quarter. Revenue was $65.6 billion, up 16% year-over-year. Azure and other cloud services grew 33% in constant currency, above our guidance of 28 to 29%. GitHub Copilot now has more than 3 million paid subscribers, achieving our target ahead of schedule. Microsoft 365 Copilot is now broadly deployed across Fortune 500 companies, with more than 70% of the Fortune 500 using it."
    },
    {
      "speaker_id": "amy-hood",
      "speaker_name": "Amy Hood",
      "speaker_role": "CFO",
      "timestamp": "00:20:00",
      "text": "Commercial cloud revenue was $38.9 billion, up 22% year-over-year. Operating income was $30.6 billion at a 47% operating margin. For fiscal Q2 2025, we expect Azure growth of 31 to 32% in constant currency, reflecting a meaningful acceleration. Capital expenditures were $20 billion this quarter as we continue to invest in AI infrastructure ahead of demand."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:38:00",
      "text": "Our next question comes from Brent Thill at Jefferies."
    },
    {
      "speaker_id": "analyst-brent-thill",
      "speaker_name": "Brent Thill",
      "speaker_role": "Analyst",
      "timestamp": "00:38:20",
      "text": "Amy, how should we think about the operating margin trajectory for the remainder of fiscal 2025 as CapEx remains elevated?"
    }
  ],
