  "title": "Apple Q3 2024 Earnings Call",
  "datetime": "2024-10-31T21:00:00Z",
  "period": "CY2024_Q3",
  "location": "Cupertino, CA",
  "url": "https://investor.apple.com/",
  "turns": [
    {
      "speaker_id": "tim-cook",
      "speaker_name": "Tim Cook",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Q3 was a record September quarter. Total revenue was $94.9 billion, up 6% year-over-year. iPhone revenue grew 6% to $46.2 billion, with strong early demand for iPhone 16. Apple Intelligence features launched in the US on iOS 18.1, with rollouts to additional markets and languages planned through early 2025. We expect the Apple Intelligence feature set to be substantially complete globally by the middle of 2025."
    },
    {
      "speaker_id": "kevan-parekh",
      "speaker_name": "Kevan Parekh",
      "speaker_role": "CFO",
      "timestamp": "00:20:00",
      "text": "Gross margin for the quarter was 46.2%, comfortably above 45% and consistent with our commitment. Services revenue was $25.0 billion, up 12% year-over-year. We expect Q4 revenue of $89 to $93 billion with gross margins of 46.5% to 47.5%. Operating expenses are expected to be $15.1 to $15.3 billion."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Tim, can you characterize the early response to Apple Intelligence features and whether it is translating into incremental device upgrades as you expected?"
    }
  ],
