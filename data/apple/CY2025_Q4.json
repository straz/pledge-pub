  "location": "Cupertino, CA",
  "url": "https://investor.apple.com/",
  "turns": [
    {
      "speaker_id": "tim-cook",
      "speaker_name": "Tim Cook",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Q4 2025 was a record quarter for Apple. iPhone revenue grew 6% to $71.2 billion as iPhone 17 demand exceeded supply in the first six weeks. Full-year Services revenue was $112.4 billion, surpassing our $110 billion target. Vision Pro Gen 2 shipped in November with exceptional initial reviews and a 90-day sell-through rate 3x that of Vision Pro Gen 1. We expect to begin calendar 2026 with continued strong momentum across the entire portfolio."
    },
    {
      "speaker_id": "kevan-parekh",
      "speaker_name": "Kevan Parekh",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Q4 total revenue was $123.1 billion, up 7% year-over-year. Gross margin was 47.9%. Full year 2025 revenue was $401.4 billion, the first time Apple has crossed $400 billion in annual revenue. We returned $31.2 billion to shareholders in Q4. For Q1 2026, we expect revenue of $121–125 billion and a gross margin of 47.5–48.5%."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:38:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:38:20",
      "text": "Tim, Vision Pro Gen 2 sell-through 3x Gen 1 — how are you thinking about scaling production and what does the unit economics path to scale look like?"
    }
  ],
