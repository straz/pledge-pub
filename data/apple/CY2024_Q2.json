{
  "company_id": "apple",
  "title": "Apple Q2 2024 Earnings Call",
  "datetime": "2024-08-01T21:00:00Z",
  "period": "CY2024_Q2",
  "location": "Cupertino, CA",
  "url": "https://investor.apple.com/",
  "turns": [
    {
      "speaker_id": "tim-cook",
      "speaker_name": "Tim Cook",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Our June quarter revenue was $85.8 billion, down 1% year-over-year, primarily due to iPhone softness in China. Services revenue set a new all-time record of $24.2 billion, growing 14% year-over-year. We launched Apple Intelligence at WWDC with an expanded feature set shipping in fall 2024. We expect Apple Intelligence to meaningfully contribute to Services revenue growth in fiscal 2025 as it drives increased engagement across our installed base."
    },
    {
      "speaker_id": "kevan-parekh",
      "speaker_name": "Kevan Parekh",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Gross margin was 46.3% for the quarter, at the high end of our guidance range of 45.5% to 46.5%. We expect Q3 gross margin of 46.0% to 47.0%, and we remain confident in our ability to sustain gross margins above 45% as we scale Apple Intelligence features. Services gross margin expanded to 74.0%, and we believe the Services segment will exceed $130 billion in revenue for full calendar year 2025."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Tim, can you speak to your confidence in the iPhone upgrade cycle driven by Apple Intelligence, and how you're thinking about the China market recovery?"
    }
  ],
