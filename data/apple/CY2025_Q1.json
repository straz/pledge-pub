{
  "company_id": "apple",
  "title": "Apple Q1 2025 Earnings Call",
  "datetime": "2025-05-01T21:00:00Z",
  "period": "CY2025_Q1",
  "location": "Cupertino, CA",
  "url": "https://investor.apple.com/",
  "turns": [
    {
      "speaker_id": "tim-cook",
      "speaker_name": "Tim Cook",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "We had a very strong start to 2025. iPhone revenue grew 2% to $46.8 billion as the iPhone 16 cycle continues to resonate, particularly in emerging markets. India became our fastest-growing major market, with revenue up over 30% year-over-year. Apple Intelligence is now available in 34 languages and is driving meaningfully higher upgrade intent among surveyed users. We expect iPhone revenue to grow mid-single digits for the full calendar year."
    },
    {
      "speaker_id": "kevan-parekh",
      "speaker_name": "Kevan Parekh",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Total revenue was $95.4 billion, up 5% year-over-year. Services revenue reached $26.6 billion, up 13%, setting another all-time record. Gross margin was 47.1%. We returned $29 billion to shareholders during the quarter. For Q2 2025, we expect revenue of $88–92 billion and a gross margin of 46.5–47.5%."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Tim, India at 30% growth is striking. Is that driven by local manufacturing economics, or is it primarily consumer demand dynamics that you'd expect to sustain?"
    }
  ],
