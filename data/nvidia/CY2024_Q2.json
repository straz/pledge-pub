{
  "company_id": "nvidia",
  "title": "Nvidia Q2 2024 Earnings Call",
  "datetime": "2024-08-28T21:00:00Z",
  "period": "CY2024_Q2",
  "location": "Santa Clara, CA",
  "url": "https://investor.nvidia.com/",
  "turns": [
    {
      "speaker_id": "jensen-huang",
      "speaker_name": "Jensen Huang",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Q2 was our strongest quarter in company history. Revenue was $30.0 billion, up 122% year-over-year. Data Center revenue was $26.3 billion, up 154%. Blackwell production is ramping and we expect to ship several billion dollars of Blackwell GPUs in Q3, with production increasing substantially each quarter through fiscal 2026. Demand for Blackwell far exceeds supply and we expect this imbalance to persist well into next year."
    },
    {
      "speaker_id": "colette-kress",
      "speaker_name": "Colette Kress",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "GAAP gross margin was 78.4%, and non-GAAP gross margin was 78.9%. For Q3, we expect revenue of approximately $32.5 billion, plus or minus 2%. We expect non-GAAP gross margin to be 74.6%, reflecting Blackwell product ramp costs. We expect gross margins to return to the mid-70% range as Blackwell production matures in the second half of fiscal 2026."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Brent Thill at Jefferies."
    },
    {
      "speaker_id": "analyst-brent-thill",
      "speaker_name": "Brent Thill",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Jensen, can you give us more detail on Blackwell's production timeline and whether the thermal issues we've seen reported are fully resolved?"
    }
  ],
