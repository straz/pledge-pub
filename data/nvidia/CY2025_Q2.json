  "location": "Santa Clara, CA",
  "url": "https://investor.nvidia.com/",
  "turns": [
    {
      "speaker_id": "jensen-huang",
      "speaker_name": "Jensen Huang",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Data center revenue reached $46.5 billion in Q2, up 84% year-over-year. We are now shipping our next-generation GB300 NVL72 systems alongside Blackwell, offering a 50% improvement in inference throughput. NIM — our inference microservices — are deployed by over 5,000 enterprises globally, creating a software flywheel on top of our hardware. The inference market is expanding faster than the training market for the first time in AI history, and Nvidia is uniquely positioned for both."
    },
    {
      "speaker_id": "colette-kress",
      "speaker_name": "Colette Kress",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Total revenue was $50.8 billion, up 78% year-over-year. Gross margin was 74.6%. We returned $8.0 billion to shareholders through buybacks. For Q3, we expect revenue of $52.5 billion, plus or minus 2%, with gross margin of approximately 74.5%."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:38:00",
      "text": "Our next question comes from Ben Reitzes at Melius Research."
    },
    {
      "speaker_id": "analyst-ben-reitzes",
      "speaker_name": "Ben Reitzes",
      "speaker_role": "Analyst",
      "timestamp": "00:38:20",
      "text": "Jensen, 5,000 NIM enterprise deployments — how does that translate to software revenue, and is there a path to NIM generating $5 billion or more in annual revenue within two years?"
    }
  ],
