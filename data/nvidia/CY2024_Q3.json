{
  "company_id": "nvidia",
  "title": "Nvidia Q3 2024 Earnings Call",
  "datetime": "2024-11-20T22:00:00Z",
  "period": "CY2024_Q3",
  "location": "Santa Clara, CA",
  "url": "https://investor.nvidia.com/",
  "turns": [
    {
      "speaker_id": "jensen-huang",
      "speaker_name": "Jensen Huang",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Q3 was phenomenal. Revenue was $35.1 billion, up 94% year-over-year. Blackwell production has ramped faster than any product in our history — we shipped $5.5 billion of Blackwell-based products in Q3, exceeding our own expectations. Blackwell demand is extraordinary. We expect Blackwell to ramp to $8 billion or more in Q4 revenue. Data centers are now building out for trillion-parameter model training and inference at scale."
    },
    {
      "speaker_id": "colette-kress",
      "speaker_name": "Colette Kress",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "GAAP gross margin was 74.6%, and non-GAAP gross margin was 75%, in line with our guidance. Q3 Data Center revenue was $30.8 billion, up 112% year-over-year. For Q4, we expect revenue of $37.5 billion, plus or minus 2%. Gross margins will be approximately 73% non-GAAP as Blackwell continues to ramp. We expect sequential revenue growth to continue through fiscal 2026."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:38:00",
      "text": "Our next question comes from Brent Thill at Jefferies."
    },
    {
      "speaker_id": "analyst-brent-thill",
      "speaker_name": "Brent Thill",
      "speaker_role": "Analyst",
      "timestamp": "00:38:20",
      "text": "Jensen, can you help us understand how you see the competitive landscape evolving with AMD gaining AI GPU share and custom silicon from hyperscalers?"
    }
  ],
