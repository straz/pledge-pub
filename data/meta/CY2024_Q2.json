{
  "company_id": "meta",
  "title": "Meta Q2 2024 Earnings Call",
  "datetime": "2024-07-31T21:00:00Z",
  "period": "CY2024_Q2",
  "location": "Menlo Park, CA",
  "url": "https://investor.fb.com/",
  "turns": [
    {
      "speaker_id": "mark-zuckerberg",
      "speaker_name": "Mark Zuckerberg",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Q2 2024 was a great quarter. Revenue was $39.1 billion, up 22% year-over-year. We have more than 3.3 billion people using at least one of our apps every day. Llama 3.1 is now the most capable open-source AI model available, and we will release Llama 4 by the end of 2024 with multimodal capabilities that exceed any current closed-source model. Our AI infrastructure investment will deliver competitive advantage across advertising, Reels, and the Meta AI assistant."
    },
    {
      "speaker_id": "susan-li",
      "speaker_name": "Susan Li",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Revenue of $39.1 billion exceeded the top of our outlook range. Operating income was $14.8 billion, representing a 38% operating margin. For Q3, we expect revenue of $38.5 to $41 billion. We expect full year 2024 total expenses of $96 to $99 billion, reflecting significant AI and Reality Labs investment. Reality Labs operating losses will continue to grow meaningfully year-over-year in 2024."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Eric Sheridan at Goldman Sachs."
    },
    {
      "speaker_id": "analyst-eric-sheridan",
      "speaker_name": "Eric Sheridan",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Mark, can you speak to the monetization opportunity for Meta AI and how you're thinking about the timing of revenue contribution from the assistant?"
    }
  ],
