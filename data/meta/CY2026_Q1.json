    {
      "speaker_id": "mark-zuckerberg",
      "speaker_name": "Mark Zuckerberg",
      "speaker_role": "CEO",
      "timestamp": "00:01:00",
      "text": "Q1 2026 was another strong quarter with revenue growing 17% to $48.8 billion. Meta AI crossed 2 billion monthly active users in February. Llama 5 shipped in March and initial benchmarks show it matching GPT-5 on mathematical reasoning. Our AI infrastructure investments are generating measurable ROI — AI-driven ad optimization contributed an estimated 8 percentage points to revenue growth this quarter."
    },
    {
      "speaker_id": "susan-li",
      "speaker_name": "Susan Li",
      "speaker_role": "CFO",
      "timestamp": "00:18:00",
      "text": "Revenue was $48.8 billion, up 17%. Operating income was $22.1 billion with a 45.3% margin. Capex was $19.1 billion, tracking to the $70–80 billion full-year range. For Q2 2026, we are guiding revenue of $51–54 billion. We continue to invest heavily in AI infrastructure with no change to our full-year capex guidance."
    },
    {
      "speaker_id": "operator",
      "speaker_name": "Operator",
      "speaker_role": "Operator",
      "timestamp": "00:36:00",
      "text": "Our next question comes from Eric Sheridan at Goldman Sachs."
    },
    {
      "speaker_id": "analyst-eric-sheridan",
      "speaker_name": "Eric Sheridan",
      "speaker_role": "Analyst",
      "timestamp": "00:36:20",
      "text": "Mark, 8 percentage points of revenue growth from AI ad optimization — how do you measure that attribution and does it have a ceiling as ad load efficiency approaches theoretical limits?"
    }
  ],
